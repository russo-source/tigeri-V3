{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ExpressDirectoryBucketSession",
      "Effect": "Allow",
      "Action": [
        "s3express:CreateSession"
      ],
      "Resource": "arn:aws:s3express:REPLACE_WITH_REGION:REPLACE_WITH_ACCOUNT_ID:bucket/REPLACE_WITH_BUCKET_NAME"
    },
    {
      "Sid": "S3ObjectAccessOnDirectoryBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3express:REPLACE_WITH_REGION:REPLACE_WITH_ACCOUNT_ID:bucket/REPLACE_WITH_BUCKET_NAME",
        "arn:aws:s3express:REPLACE_WITH_REGION:REPLACE_WITH_ACCOUNT_ID:bucket/REPLACE_WITH_BUCKET_NAME/*"
      ]
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
  ]
}
